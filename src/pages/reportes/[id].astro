---
export const prerender = true;
import AppLayout from '../../layouts/AppLayout.astro';
import StickyHeader from '../../components/StickyHeader';
import BottomNav from '../../components/BottomNav';
import ReporteDetalle from '../../components/ReporteDetalle';
import { query } from '../../lib/db';

export async function getStaticPaths() {
  try {
    const rows = await query<{ id: string }[]>('SELECT id FROM registros_combustible');
    return rows.map((row) => ({
      params: { id: row.id },
    }));
  } catch (e) {
    console.warn('[prerender] No se pudieron obtener IDs para reportes, se renderizarán vía SSR:', (e as Error).message);
    return [];
  }
}

const id = Astro.params.id as string;
---

<AppLayout title="Detalle de Reporte">
  <fragment slot="header">
    <StickyHeader title="Detalle" client:load showBack />
  </fragment>
  <ReporteDetalle client:load id={id} />
  <fragment slot="nav">
    <BottomNav client:load />
  </fragment>
</AppLayout>
