# ──────────────────────────────────────────────
# FleetFuel — Variables de entorno
# ──────────────────────────────────────────────
# Copiar a .env y ajustar según el entorno.
# docker-compose lee automáticamente este archivo.

# Para Docker: DB_HOST=db, DB_PORT=3306
# Para local:   DB_HOST=localhost, DB_PORT=3306
DB_HOST=db
DB_PORT=3306
DB_USER=usr_fleetfuel
DB_PASSWORD=pwd_fleetfuel
DB_NAME=db_fleetfuel

# Opcionales (docker-compose)
DB_ROOT_PASSWORD=pwd_fleetfuel
APP_PORT=8188
DB_PORT_EXTERNAL=3307
PMA_PORT=82
